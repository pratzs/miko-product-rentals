{% comment %}
  Miko Rental Calendar - Theme App Extension Block
  Add this block to any product page to show a date picker and pricing calculator.
  Customers pick their start and end date; the block calls the Miko Rentals API
  to check availability and show the price before adding to cart.
{% endcomment %}

{%- comment -%}
  Only render this widget when the product has been enabled as a rental.
  The merchant adds this block once to the product template; we conditionally
  show it per product based on the `miko.is_rental` metafield set by the app.
{%- endcomment -%}
{%- unless product.metafields.miko.is_rental -%}
  {%- comment -%}
    Product is not configured as a rental (or this is a non-product page).
    Show a visible placeholder so merchants and Shopify reviewers understand
    what to do rather than seeing a completely blank section.
  {%- endcomment -%}
  <div id="miko-setup-notice" style="
    padding: 20px 24px;
    border: 2px dashed #c9cccf;
    border-radius: 8px;
    background: #f6f6f7;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    text-align: center;
    color: #6d7175;
  ">
    <svg width="28" height="28" viewBox="0 0 20 20" fill="none" style="display:block;margin:0 auto 10px;" aria-hidden="true">
      <rect x="2" y="4" width="16" height="14" rx="2" stroke="#6d7175" stroke-width="1.5"/>
      <path d="M2 8h16" stroke="#6d7175" stroke-width="1.5"/>
      <path d="M6 2v3M14 2v3" stroke="#6d7175" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <strong style="display:block;margin-bottom:6px;color:#202223;font-size:14px;">Miko Rental Calendar</strong>
    {%- if request.page_type != 'product' -%}
      <span style="font-size:13px;">
        This block only works on <strong>product pages</strong>.<br>
        Add it to your <strong>Product</strong> template (not a Page or other template) in the theme editor.
      </span>
    {%- else -%}
      <span style="font-size:13px;">
        This product isn&apos;t configured as a rental yet.<br>
        Open the <strong>Miko Product Rentals</strong> app, go to <strong>Products</strong>, and enable this product as a rental to show the booking calendar here.
      </span>
    {%- endif -%}
  </div>
{%- else -%}

{{ 'rental-calendar.css' | asset_url | stylesheet_tag }}

<style>
  /*
   * Always hide the theme's "Sold out" button/badge on rental product pages.
   * Availability is managed by Miko's calendar — the theme's stock-based
   * sold-out state is irrelevant and confuses customers.
   * We target disabled submit buttons that contain "Sold out" text via the
   * [disabled] + content approach used by Dawn and most popular themes.
   */
  form[action*="/cart/add"] button[type="submit"][disabled]:not(#miko-add-to-cart),
  form[action*="/cart/add"] button.product-form__submit[disabled],
  .product-form__submit[disabled],
  button.btn--sold-out,
  button[name="add"][disabled],
  .sold-out-btn,
  .product__availability .sold-out,
  .product-availability--sold-out { display: none !important; }
</style>

{% if block.settings.rental_only %}
<style>
  /* Hide the theme's default price and buy button for rental-only products */
  .product-form__buttons,
  .product__buy-buttons,
  .shopify-payment-button,
  .product-form .product-form__cart-submit,
  form[action*="/cart/add"] .btn,
  form[action*="/cart/add"] button[type="submit"],
  form[action*="/cart/add"] .product-form__submit,
  [data-type="add-to-cart-form"] button[type="submit"] { display: none !important; }

  .price,
  .product__price,
  .product-single__price,
  .product__price-wrapper,
  .price-item,
  [data-product-price],
  .product-block--price { display: none !important; }
</style>
{% endif %}

<div
  id="miko-rental-widget"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id | prepend: 'gid://shopify/Product/' }}"
  data-app-url="{{ block.settings.app_url | default: 'https://miko-product-rentals-production.up.railway.app' }}"
  data-currency="{{ cart.currency.iso_code }}"
  data-min-days="{{ block.settings.min_days | default: 1 }}"
>
  <div class="miko-widget-inner">
    <div class="miko-widget-header">
      <svg class="miko-calendar-icon" width="18" height="18" viewBox="0 0 20 20" fill="none">
        <rect x="2" y="4" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
        <path d="M2 8h16" stroke="currentColor" stroke-width="1.5"/>
        <path d="M6 2v3M14 2v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span>{{ block.settings.heading | default: 'Choose your rental dates' }}</span>
    </div>

    <div class="miko-date-row">
      <div class="miko-date-field">
        <label for="miko-start-date">Rental start</label>
        <input type="date" id="miko-start-date" class="miko-date-input" />
      </div>
      <div class="miko-date-arrow">→</div>
      <div class="miko-date-field">
        <label for="miko-end-date">Return by</label>
        <input type="date" id="miko-end-date" class="miko-date-input" />
      </div>
    </div>

    <div id="miko-unit-row" class="miko-unit-row miko-msg--hidden">
      <label for="miko-units" class="miko-unit-label">Units to rent</label>
      <div class="miko-unit-control">
        <button type="button" id="miko-unit-minus" class="miko-unit-btn" aria-label="Decrease units">−</button>
        <input type="number" id="miko-units" class="miko-unit-input" value="1" min="1" step="1" />
        <button type="button" id="miko-unit-plus" class="miko-unit-btn" aria-label="Increase units">+</button>
      </div>
      <span id="miko-unit-available" class="miko-unit-available"></span>
    </div>

    <div id="miko-availability-msg" class="miko-msg miko-msg--hidden"></div>

    <div id="miko-pricing-panel" class="miko-pricing-panel miko-msg--hidden">
      <div class="miko-pricing-row">
        <span id="miko-breakdown-label" class="miko-breakdown"></span>
        <span id="miko-rental-price" class="miko-price"></span>
      </div>
      <div id="miko-deposit-row" class="miko-pricing-row miko-pricing-row--sub miko-msg--hidden">
        <span>Security deposit (refundable)</span>
        <span id="miko-deposit-price"></span>
      </div>
      <div class="miko-pricing-row miko-pricing-row--total">
        <span>Total at checkout</span>
        <span id="miko-total-price"></span>
      </div>
      <p class="miko-cart-note">Your cart may show the product's regular price. The rental amount above is what you'll actually be charged at checkout.</p>
    </div>

    <div id="miko-notes" class="miko-notes miko-msg--hidden"></div>

    <button id="miko-add-to-cart" class="miko-btn miko-btn--disabled" disabled>
      Select dates to continue
    </button>

    <p class="miko-powered">
      Powered by <a href="https://apps.shopify.com/miko-product-rentals" target="_blank" rel="noopener">Miko Rentals</a>
    </p>
  </div>

  {%- comment -%}
    Hidden form submitted to /cart/add.js. All private fields prefixed with
    `_miko_` are hidden from the customer-facing cart UI by Shopify because
    the key starts with an underscore. The Cart Transform Function reads
    `_miko_total_price` to set the actual checkout price.
  {%- endcomment -%}
  <form id="miko-cart-form" style="display:none;" action="/cart/add" method="post" enctype="multipart/form-data">
    <input type="hidden" name="id" id="miko-variant-id" value="{{ product.selected_or_first_available_variant.id }}" />
    {%- comment -%}
      Cart quantity mirrors the number of units. The Cart Transform Function
      computes per-unit price so Shopify multiplies it correctly across the
      cart line.
    {%- endcomment -%}
    <input type="hidden" name="quantity" id="miko-cart-quantity" value="1" />
    {%- comment -%}Visible in cart and order emails{%- endcomment -%}
    <input type="hidden" name="properties[Rental start]" id="miko-prop-start-display" value="" />
    <input type="hidden" name="properties[Return by]" id="miko-prop-end-display" value="" />
    <input type="hidden" name="properties[Rental duration]" id="miko-prop-duration" value="" />
    <input type="hidden" name="properties[Rental price]" id="miko-prop-price" value="" />
    <input type="hidden" name="properties[Deposit]" id="miko-prop-deposit" value="" />
    {%- comment -%}
      Single consolidated private property read by the Cart Transform Function
      and the orders/paid webhook. Keeps the admin order page tidy - only one
      cryptic row instead of six.
    {%- endcomment -%}
    <input type="hidden" name="properties[_miko_data]" id="miko-prop-data" value="" />
  </form>
</div>

<script src="{{ 'rental-calendar.js' | asset_url }}" defer></script>

{%- endunless -%}

{% schema %}
{
  "name": "Miko Rental Calendar",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Widget heading",
      "default": "Choose your rental dates"
    },
    {
      "type": "checkbox",
      "id": "rental_only",
      "label": "Rental only product",
      "info": "Turn this on to hide the regular price and Add to cart button. Use this when the product is available for rental only and should not be purchased outright.",
      "default": false
    },
    {
      "type": "url",
      "id": "app_url",
      "label": "App URL (advanced)",
      "info": "Leave this blank. It is only needed if you run Miko Rentals on a custom domain."
    },
    {
      "type": "range",
      "id": "min_days",
      "label": "Minimum rental days shown",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 1
    }
  ]
}
{% endschema %}
