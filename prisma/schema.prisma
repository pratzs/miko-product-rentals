generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator          Boolean?  @default(false)
  emailVerified         Boolean?  @default(false)
  refreshToken          String?
  refreshTokenExpires   DateTime?
}

// One row per installed shop — stores all settings for that merchant.
model ShopConfig {
  id                  String   @id @default(cuid())
  shop                String   @unique
  accessToken         String   @default("")
  planName            String   @default("free")
  currency            String   @default("USD")
  timezone            String   @default("UTC")
  // How many hours before the rental start date the merchant wants
  // to stop accepting new bookings (buffer time).
  bufferHours         Int      @default(24)
  // Days of grace after the return date before a late fee kicks in.
  gracePeriodDays     Int      @default(0)
  // Flat daily late fee in the shop's currency.
  lateFeePerDay       Float    @default(0)
  onboardingCompleted Boolean  @default(false)
  // First time the storefront booking calendar called our API for this shop.
  // Used to auto-detect that the theme block is live during onboarding.
  widgetSeenAt        DateTime?
  // First time the sitewide display-rules App Embed pinged our API for this
  // shop. Used to auto-detect that the merchant has enabled the embed during
  // onboarding so they get the hide-price/buy-button behaviour.
  displayRulesSeenAt  DateTime?
  // On paid plans, merchants can choose to show the "Powered by Miko Rentals"
  // credit on their storefront widget. Forced on for the Free plan.
  showPoweredBy       Boolean   @default(false)
  // Email identity — shown to customers on every email sent.
  senderName          String   @default("")   // From: display name, e.g. "Kiwi Surf Gear"
  replyToEmail        String   @default("")   // Reply-To address, e.g. owner@kiwisurfgear.co.nz
  // BYO SMTP — available on Starter plan and above.
  smtpHost            String   @default("")
  smtpPort            Int      @default(587)
  smtpUser            String   @default("")
  smtpPass            String   @default("")
  smtpFromEmail       String   @default("")
  smtpFromName        String   @default("")
  smtpSecure          Boolean  @default(false)
  // Brand visuals — used in email templates.
  brandLogoUrl        String?
  brandPrimaryColor   String?  @default("#1a1a1a")
  brandName           String?
  // Shopify's real shop name (e.g. "Kiwi Surf Gear") fetched on install.
  // Used as the email header fallback when brandLogoUrl is empty and
  // brandName hasn't been set by the merchant.
  shopName            String?
  installedAt         DateTime @default(now())
  // First time the merchant ever activated a paid plan. Anchored to first
  // subscription start so reinstalls don't get a fresh trial. Null = never.
  trialStartedAt      DateTime?
  // Set when Shopify confirms the subscription was cancelled or the app was
  // uninstalled. Used to show a "reactivate your plan" banner on reinstall.
  subscriptionCancelledAt DateTime?
  // Tracks the Cart Transform Function record so we can clean it up on
  // uninstall and avoid orphaned records.
  cartTransformId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  rentalProducts RentalProduct[]
  bookings       RentalBooking[]
  blockedDates   BlockedDate[]
}

model EmailTemplate {
  id        String   @id @default(cuid())
  shop      String
  type      String   // confirmation | return_reminder | overdue | custom
  name      String
  subject   String   @default("")
  blocks    Json
  html      String   @default("") @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([shop, type])
}

// Each Shopify product that the merchant has enabled for rental.
// For single-variant products, the pricing/units fields on this row are the
// source of truth. For multi-variant products, the per-variant RentalVariant
// rows take precedence and the product-level fields act as defaults that
// new variants inherit.
model RentalProduct {
  id                String   @id @default(cuid())
  shop              String
  shopifyProductId  String   // Shopify product GID e.g. "gid://shopify/Product/123"
  shopifyProductTitle String @default("")
  shopifyProductImage String @default("")
  // Total physical units available for rental.
  totalUnits        Int      @default(1)
  // Pricing options — merchant fills in what makes sense for their product.
  pricePerDay       Float    @default(0)
  pricePerWeek      Float    @default(0)   // 0 means not offered
  pricePerMonth     Float    @default(0)   // 0 means not offered
  // Minimum rental duration in days (e.g. 2 = must rent for at least 2 days).
  minRentalDays     Int      @default(1)
  // Maximum rental duration in days (0 = no maximum).
  maxRentalDays     Int      @default(0)
  // Deposit — flat amount in the shop's currency (0 = no deposit).
  depositAmount     Float    @default(0)
  // Whether the deposit is automatically released when the item is marked returned.
  autoReleaseDeposit Boolean @default(true)
  // Extra notes shown to the customer on the product page.
  rentalNotes       String   @default("")
  isActive          Boolean  @default(true)
  // When true (default), the app overrides Shopify's sold-out status so
  // customers can still add a rental to cart even when Shopify inventory is
  // zero. Miko's own calendar is the source of truth for rental availability.
  // When false, Shopify inventory gates rentals — the variant must show as
  // in-stock in Shopify for a rental cart-add to succeed.
  allowRentalWhenSoldOut Boolean @default(true)
  // True when the Shopify product has multiple meaningful variants (more than
  // one variant, or one variant whose title is not "Default Title"). When
  // true, the storefront widget shows a variant picker and our pricing and
  // availability APIs require a variantId.
  hasVariants       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shopConfig ShopConfig      @relation(fields: [shop], references: [shop])
  bookings   RentalBooking[]
  variants   RentalVariant[]

  @@unique([shop, shopifyProductId])
  @@index([shop])
}

// Per-variant rental configuration. Created when a merchant configures a
// rental for a product that has multiple Shopify variants. Each variant gets
// its own pricing, units, and availability calendar.
model RentalVariant {
  id                  String   @id @default(cuid())
  shop                String
  rentalProductId     String
  shopifyVariantId    String   // gid://shopify/ProductVariant/123
  shopifyVariantTitle String   @default("")
  // Per-variant overrides. Defaults inherit from the parent RentalProduct
  // when first synced from Shopify so merchants can leave them alone if they
  // want all variants priced the same.
  totalUnits          Int      @default(1)
  pricePerDay         Float    @default(0)
  pricePerWeek        Float    @default(0)
  pricePerMonth       Float    @default(0)
  depositAmount       Float    @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  rentalProduct RentalProduct   @relation(fields: [rentalProductId], references: [id], onDelete: Cascade)
  bookings      RentalBooking[]

  @@unique([rentalProductId, shopifyVariantId])
  @@index([shop])
  @@index([rentalProductId])
}

// One row per rental booking made by a customer.
model RentalBooking {
  id                  String   @id @default(cuid())
  shop                String
  rentalProductId     String
  // Shopify order info — populated when the order is paid.
  shopifyOrderId      String   @default("")
  shopifyOrderName    String   @default("")  // e.g. "#1042"
  shopifyLineItemId   String   @default("")
  // Set when the booked product had multiple Shopify variants. Tells the
  // merchant which variant the customer rented so they can pull the right
  // physical unit off the shelf, and lets us scope availability per-variant.
  shopifyVariantId    String   @default("")
  rentalVariantId     String?
  // Customer info — copied from the Shopify order so we keep it even if
  // the Shopify customer record is later deleted.
  customerName        String   @default("")
  customerEmail       String   @default("")
  customerPhone       String   @default("")
  // Rental period.
  startDate           DateTime
  endDate             DateTime
  // Number of units rented in this booking (usually 1).
  unitsRented         Int      @default(1)
  // Pricing breakdown stored at booking time so it's locked in.
  rentalDays          Int      @default(0)
  rentalPrice         Float    @default(0)
  depositAmount       Float    @default(0)
  depositStatus       String   @default("pending")  // pending | held | released | forfeited
  totalCharged        Float    @default(0)
  // Booking lifecycle.
  // pending   = created, waiting for payment
  // confirmed = payment received
  // active    = rental has started (start date reached)
  // returned  = merchant marked as returned
  // overdue   = past return date, not yet returned
  // cancelled = cancelled before start
  status              String   @default("pending")
  // Late fee tracking.
  lateFeeCharged      Float    @default(0)
  lateFeeInvoiceId    String   @default("")
  // Internal notes the merchant can add.
  merchantNotes       String   @default("")
  returnedAt          DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  shopConfig     ShopConfig     @relation(fields: [shop], references: [shop])
  rentalProduct  RentalProduct  @relation(fields: [rentalProductId], references: [id])
  rentalVariant  RentalVariant? @relation(fields: [rentalVariantId], references: [id])

  @@index([shop, status])
  @@index([shop, startDate, endDate])
  @@index([shop, customerEmail])
  @@index([rentalProductId, startDate, endDate])
  @@index([rentalVariantId, startDate, endDate])
}

// Dates the merchant has manually blocked for a product (e.g. maintenance,
// holidays). These prevent new bookings regardless of unit availability.
model BlockedDate {
  id               String   @id @default(cuid())
  shop             String
  // null = applies to all products in the shop
  shopifyProductId String?
  blockedDate      DateTime @db.Date
  reason           String   @default("")
  createdAt        DateTime @default(now())

  shopConfig ShopConfig @relation(fields: [shop], references: [shop])

  @@index([shop, shopifyProductId, blockedDate])
}

// Tracks every email we send so we don't send duplicates and the merchant
// can see the communication history inside the booking detail page.
model EmailLog {
  id            String   @id @default(cuid())
  shop          String
  bookingId     String
  type          String   // confirmation | return_reminder | overdue | late_fee
  recipientEmail String
  subject       String
  status        String   @default("sent")  // sent | failed
  sentAt        DateTime @default(now())

  @@index([shop, bookingId])
}
